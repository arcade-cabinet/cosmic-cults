{
  "name": "@cosmic-cults/core",
  "version": "0.1.0",
  "description": "Core utilities and hex grid math for Cosmic Cults",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./hex": {
      "types": "./src/hex/index.ts",
      "import": "./src/hex/index.ts"
    }
  },
  "scripts": {
    "check": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@cosmic-cults/types": "workspace:*"
  },
  "devDependencies": {
    "fast-check": "^4.5.3",
    "typescript": "~5.9.3",
    "vitest": "^4.0.17"
  }
}
