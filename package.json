{
  "name": "cosmic-cults",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "packageManager": "pnpm@10.20.0",
  "scripts": {
    "dev": "pnpm --filter @cosmic-cults/web dev",
    "dev:mobile": "pnpm --filter @cosmic-cults/mobile exec expo start --dev-client",
    "build": "pnpm --filter @cosmic-cults/web build",
    "preview": "pnpm --filter @cosmic-cults/web preview",
    "lint": "biome check .",
    "format": "biome check --write .",
    "check": "pnpm -r run check",
    "test": "pnpm -r test",
    "test:coverage": "pnpm -r test:coverage"
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.11",
    "@types/node": "^25.0.6",
    "typescript": "~5.9.3"
  }
}
